rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ── Products & Collections ────────────────────────────────────
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /collections/{colId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Site Config / Content ─────────────────────────────────────
    match /siteConfig/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /loyaltyConfig/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /content/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /banners/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /announcements/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /testimonials/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /faq/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /pages/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /blog/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Orders ────────────────────────────────────────────────────
    match /orders/{orderId} {
      // Owner can read their own orders
      allow read: if isOwner(resource.data.userId) || isAdmin();
      // New orders created only via API route (admin SDK bypasses rules)
      allow create: if false;
      // Status updates only by admin
      allow update, delete: if isAdmin();
    }

    // ── Users ─────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // ── Admins (read-only via app; managed in console) ────────────
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── Restock notifications ─────────────────────────────────────
    match /restockNotifications/{docId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // ── Deny everything else ──────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
