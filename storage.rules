rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }

    // Product & collection images/videos — public read, admin write (max 100 MB for video)
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() &&
        (request.resource == null || request.resource.size <= 104857600);
    }

    match /collections/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /banners/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User avatars — owner read/write; images only, max 5 MB
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == userId
        && request.resource.contentType.matches('image/.*')
        && request.resource.size <= 5 * 1024 * 1024;
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
