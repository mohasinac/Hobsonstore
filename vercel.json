{
  "framework": "nextjs",
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "github": {
    "enabled": true,
    "deploymentEnabled": {
      "main": true
    }
  },
  "functions": {
    "app/api/**": {
      "maxDuration": 10
    }
  },
  "crons": [
    {
      "path": "/api/cron/sitemap",
      "schedule": "30 20 * * *"
    }
  ]
}
