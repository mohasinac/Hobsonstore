{
  "name": "hobson",
  "version": "0.1.0",
  "private": true,
  "author": {
    "name": "Mohasin AC",
    "url": "https://github.com/mohasinac"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "emulators": "firebase emulators:start --import=./emulator-data --export-on-exit",
    "seed": "npx tsx scripts/seed-data.ts",
    "env:export": "npx tsx scripts/sync-env.ts export",
    "env:import": "npx tsx scripts/sync-env.ts import",
    "env:set": "npx tsx scripts/sync-env.ts set",
    "env:delete": "npx tsx scripts/sync-env.ts delete",
    "env:list": "npx tsx scripts/sync-env.ts list",
    "deploy:firebase": "firebase deploy --only firestore:rules,firestore:indexes"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.2",
    "firebase": "^12.10.0",
    "isomorphic-dompurify": "^3.0.0",
    "next": "16.1.6",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "firebase-admin": "^13.7.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
